{
  "manifest_version": 3,
  "name": "Metab",
  "version": "0.4.0",
  "description": "Learn how your mind works, one new tab at a time. Mental models, biases, emotions, and rhetoric as small daily cards.",
  "permissions": ["storage"],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
